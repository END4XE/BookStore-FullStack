<Window x:Class="BookStoreClient.CartWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BookStoreClient"
        mc:Ignorable="d"
        Title="Просмотр текущего заказа" 
        Height="450" 
        Width="600"
        WindowStartupLocation="CenterOwner">

    <Grid Background="{StaticResource MainBgBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="60"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" 
                Background="{StaticResource AdditionalBgBrush}" 
                Padding="15,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" 
                           Text="Ваша корзина" 
                           Foreground="{StaticResource TextWhiteBrush}" 
                           FontSize="18" 
                           FontWeight="Bold" 
                           VerticalAlignment="Center"/>

                <StackPanel Grid.Column="1" 
                            Orientation="Horizontal" 
                            VerticalAlignment="Center">
                    <TextBlock Text="Заказчик: " 
                               Foreground="#FFF0F5" 
                               FontSize="14" 
                               VerticalAlignment="Center"/>
                    <TextBlock x:Name="ClientFioTextBlock" 
                               Text="Гость" 
                               Foreground="{StaticResource TextWhiteBrush}" 
                               FontSize="14" 
                               FontWeight="Bold" 
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <ListBox x:Name="OrderItemsListBox" 
                 Grid.Row="1" 
                 Margin="10" 
                 HorizontalContentAlignment="Stretch" 
                 BorderThickness="0" 
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 Background="Transparent">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="#DDDDDD" 
                            BorderThickness="0,0,0,1" 
                            Padding="5,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Image Grid.Column="0" 
                                   Source="{Binding Product.ImagePath}" 
                                   Width="50" 
                                   Height="50" 
                                   Stretch="Uniform" 
                                   Margin="0,0,10,0"/>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Product.Title}" FontSize="15" FontWeight="Bold" Foreground="{StaticResource TextBlackBrush}" TextWrapping="Wrap"/>
                                <TextBlock Text="{Binding Product.Publisher}" FontSize="12" Foreground="#777777"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2" 
                                        Orientation="Horizontal" 
                                        VerticalAlignment="Center" 
                                        Margin="15,0">
                                <TextBlock Text="{Binding Quantity}" FontSize="14" FontWeight="Bold" Foreground="{StaticResource TextBlackBrush}"/>
                                <TextBlock Text=" шт. х " FontSize="14" Foreground="#666666"/>
                                <TextBlock Text="{Binding Product.Price}" FontSize="14" Foreground="{StaticResource TextBlackBrush}"/>
                                <TextBlock Text=" руб. = " FontSize="14" Foreground="#666666"/>
                                <TextBlock Text="{Binding TotalPrice}" FontSize="14" FontWeight="Bold" Foreground="{StaticResource AccentBrush}"/>
                                <TextBlock Text=" руб." FontSize="14" FontWeight="Bold" Foreground="{StaticResource AccentBrush}"/>
                            </StackPanel>

                            <Button Grid.Column="3" 
                                    Content="Удалить" 
                                    Width="70" 
                                    Height="28" 
                                    Style="{StaticResource AccentButtonStyle}"
                                    Tag="{Binding Product.SKU}" 
                                    Click="DeleteProductButton_Click"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <Border Grid.Row="2" 
                Background="#EEEEEE" 
                Padding="15,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" 
                            Orientation="Horizontal" 
                            VerticalAlignment="Center">
                    <TextBlock Text="ИТОГО К ОПЛАТЕ: " FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextBlackBrush}"/>
                    <TextBlock x:Name="TotalPriceTextBlock" Text="0" FontSize="16" FontWeight="Bold" Foreground="{StaticResource AccentBrush}"/>
                    <TextBlock Text=" рублей" FontSize="16" FontWeight="Bold" Foreground="{StaticResource AccentBrush}"/>
                </StackPanel>

                <Grid Grid.Column="1" VerticalAlignment="Center">

                    <Button x:Name="SubmitOrderButton"
                            Content="Сформировать заказ" 
                            Width="180" 
                            Height="35" 
                            Style="{StaticResource AccentButtonStyle}"
                            Click="SubmitOrderButton_Click"/>

                    <Button x:Name="SaveTicketButton" 
                            Content="💾 Сохранить талон заказа" 
                            Width="180" 
                            Height="35" 
                            Visibility="Collapsed" 
                            Style="{StaticResource AccentButtonStyle}"
                            Click="SaveTicketButton_Click"/>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>