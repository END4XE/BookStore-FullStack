<Window x:Class="BookStoreClient.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BookStoreClient"
        mc:Ignorable="d" 
        Title="Книжный магазин — Просмотр товаров" 
        Height="700" 
        Width="900" 
        WindowStartupLocation="CenterScreen">

    <Grid Background="{StaticResource MainBgBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="75"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" 
                Background="{StaticResource AdditionalBgBrush}" 
                Padding="15,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" 
                            Orientation="Horizontal" 
                            VerticalAlignment="Center">
                    <Image Source="/Images/icon.png" 
                           Width="35" 
                           Height="35" 
                           Stretch="Uniform" 
                           VerticalAlignment="Center" 
                           Margin="0,0,10,0"/>
                    <TextBlock Text="Книжный магазин" 
                               Foreground="{StaticResource TextWhiteBrush}" 
                               FontSize="20" 
                               FontWeight="Bold" 
                               VerticalAlignment="Center"/>
                    <TextBlock x:Name="CountTextBlock" 
                               Text=" (0 из 0)" 
                               Foreground="{StaticResource TextWhiteBrush}" 
                               FontSize="16" 
                               VerticalAlignment="Center" 
                               Margin="10,2,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1" 
                            Orientation="Horizontal" 
                            VerticalAlignment="Center">
                    <Button x:Name="ViewOrderButton" 
                            Content="🛒 Просмотр заказа (0)" 
                            Width="160" 
                            Height="30" 
                            Margin="0,0,10,0" 
                            Background="{StaticResource MainBgBrush}" 
                            Foreground="{StaticResource AccentBrush}" 
                            FontWeight="Bold" 
                            Visibility="Collapsed" 
                            Click="ViewOrderButton_Click"/>

                    <Button x:Name="AdminOrdersButton" 
                            Content="Работа с заказами" 
                            Width="140" 
                            Height="30" 
                            Margin="0,0,10,0" 
                            Background="{StaticResource MainBgBrush}" 
                            Foreground="{StaticResource AccentBrush}" 
                            FontWeight="Bold" 
                            Visibility="Collapsed" 
                            Click="AdminOrdersButton_Click"/>

                    <Button x:Name="LoginMenuButton" 
                            Content="Войти" 
                            Width="80" 
                            Height="30" 
                            Style="{StaticResource AccentButtonStyle}"
                            Click="LoginMenuButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <WrapPanel Grid.Row="1" 
                   Background="{StaticResource MainBgBrush}" 
                   VerticalAlignment="Center">

            <StackPanel Orientation="Horizontal" Margin="0,0,15,5">
                <TextBlock Text="Поиск:" VerticalAlignment="Center" Margin="5,0" FontWeight="SemiBold"/>
                <TextBox x:Name="SearchTextBox" Width="120" Height="25" TextChanged="FilterChanged"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,0,15,5">
                <TextBlock Text="Цена от:" VerticalAlignment="Center" Margin="5,0" FontWeight="SemiBold"/>
                <TextBox x:Name="MinPriceTextBox" Width="60" Height="25" TextChanged="FilterChanged"/>
                <TextBlock Text="до:" VerticalAlignment="Center" Margin="5,0" FontWeight="SemiBold"/>
                <TextBox x:Name="MaxPriceTextBox" Width="60" Height="25" TextChanged="FilterChanged"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,0,15,5">
                <TextBlock Text="Производитель:" VerticalAlignment="Center" Margin="5,0" FontWeight="SemiBold"/>
                <ComboBox x:Name="ManufacturerComboBox" Width="140" Height="25" SelectionChanged="FilterChanged"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,0,5,5">
                <TextBlock Text="Сортировка:" VerticalAlignment="Center" Margin="5,0" FontWeight="SemiBold"/>
                <ComboBox x:Name="SortCriterionComboBox" Width="130" Height="25" SelectedIndex="0" SelectionChanged="FilterChanged">
                    <ComboBoxItem Content="Без сортировки"/>
                    <ComboBoxItem Content="По стоимости"/>
                    <ComboBoxItem Content="По наименованию"/>
                </ComboBox>

                <ComboBox x:Name="SortDirectionComboBox" Width="120" Height="25" Margin="5,0,0,0" SelectedIndex="0" SelectionChanged="FilterChanged">
                    <ComboBoxItem Content="По возрастанию"/>
                    <ComboBoxItem Content="По убыванию"/>
                </ComboBox>
            </StackPanel>
        </WrapPanel>

        <ListBox x:Name="BooksListBox" 
                 Grid.Row="2" 
                 Margin="10" 
                 HorizontalContentAlignment="Stretch" 
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled" 
                 Background="Transparent" 
                 BorderThickness="0">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Background="{StaticResource MainBgBrush}" 
                            BorderBrush="#DDDDDD" 
                            BorderThickness="1" 
                            CornerRadius="5" 
                            Margin="0,5,0,5" 
                            Padding="15">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="130"/>
                            </Grid.ColumnDefinitions>

                            <Image Grid.Column="0" 
                                   Source="{Binding ImagePath}" 
                                   Width="110" 
                                   Height="110" 
                                   Stretch="Uniform" 
                                   HorizontalAlignment="Center" 
                                   VerticalAlignment="Center" 
                                   Margin="0,0,10,0"/>

                            <Grid Grid.Column="1" VerticalAlignment="Center" Margin="5,0,15,0">
                                <StackPanel>
                                    <TextBlock Text="{Binding Title}" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextBlackBrush}" Margin="0,0,0,4" TextWrapping="Wrap"/>
                                    <TextBlock Text="{Binding Description}" FontSize="13" Foreground="#666666" TextWrapping="Wrap" Margin="0,0,0,6"/>

                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                        <TextBlock Text="Производитель: " FontSize="12" FontWeight="SemiBold" Foreground="#555555"/>
                                        <TextBlock Text="{Binding Publisher}" FontSize="12" Foreground="#555555"/>
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Цена: " FontSize="14" FontWeight="Bold" Foreground="{StaticResource TextBlackBrush}"/>
                                        <TextBlock Text="{Binding Price}" FontSize="14" FontWeight="Bold" Foreground="{StaticResource AccentBrush}"/>
                                        <TextBlock Text=" руб." FontSize="14" FontWeight="Bold" Foreground="{StaticResource AccentBrush}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>

                            <Button Grid.Column="2" 
                                    Content="Заказать" 
                                    Width="110" 
                                    Height="35" 
                                    Style="{StaticResource AccentButtonStyle}"
                                    VerticalAlignment="Center" 
                                    HorizontalAlignment="Right" 
                                    Click="OrderButton_Click"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <TextBlock x:Name="NoResultsTextBlock"
                   Grid.Row="2"
                   Text="По вашему запросу ничего не найдено. Попробуйте изменить параметры фильтрации."
                   FontSize="16"
                   Foreground="#777777"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   TextWrapping="Wrap"
                   TextAlignment="Center"
                   Margin="20"
                   Visibility="Collapsed"/>
    </Grid>
</Window>