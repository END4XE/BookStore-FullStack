<Window x:Class="BookStoreClient.OrderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BookStoreClient"
        mc:Ignorable="d"
        Title="Заказ оформлен" 
        Height="300" 
        Width="450" 
        WindowStartupLocation="CenterOwner" 
        ResizeMode="NoResize">

    <Grid Background="{StaticResource MainBgBrush}">
        <StackPanel Margin="20" VerticalAlignment="Center">

            <TextBlock Text="Товар успешно добавлен в заказ!" 
                       FontSize="18" 
                       FontWeight="Bold" 
                       Foreground="{StaticResource AccentBrush}" 
                       HorizontalAlignment="Center" 
                       Margin="0,0,0,20"/>

            <Border BorderBrush="#DDDDDD" 
                    BorderThickness="1" 
                    Background="{StaticResource MainBgBrush}" 
                    Padding="15" 
                    CornerRadius="5">
                <StackPanel>
                    <TextBlock x:Name="TitleTextBlock" 
                               Text="Название книги" 
                               FontSize="16" 
                               FontWeight="Bold" 
                               Foreground="{StaticResource TextBlackBrush}" 
                               Margin="0,0,0,10" 
                               TextWrapping="Wrap"/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                        <TextBlock Text="Автор: " Foreground="#666666" FontWeight="SemiBold"/>
                        <TextBlock x:Name="AuthorTextBlock" Text="Имя Автора" Foreground="{StaticResource TextBlackBrush}"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                        <TextBlock Text="К оплате: " FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextBlackBrush}"/>
                        <TextBlock x:Name="PriceTextBlock" Text="0" FontSize="16" FontWeight="Bold" Foreground="{StaticResource AccentBrush}"/>
                        <TextBlock Text=" руб." FontSize="16" FontWeight="Bold" Foreground="{StaticResource AccentBrush}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Button Content="Отлично" 
                    Width="120" 
                    Height="35" 
                    Margin="0,20,0,0" 
                    Click="CloseButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
